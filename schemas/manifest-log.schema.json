{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://humancost.ai/schemas/manifest-log.schema.json",
  "title": "Manifest Log (provenance trail)",
  "description": "Every update, dated, with a content hash. Idempotent: re-applying a manifest must not append a duplicate entry.",
  "type": "object",
  "required": ["meta", "manifests"],
  "additionalProperties": false,
  "properties": {
    "meta": { "type": "object", "additionalProperties": true },
    "manifests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["manifest_id", "file", "applied_at", "sha256"],
        "additionalProperties": false,
        "properties": {
          "manifest_id": { "type": "string", "minLength": 1 },
          "file": { "type": "string" },
          "applied_at": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "summary": { "type": ["string", "null"] },
          "analyst": { "type": ["string", "null"] },
          "ops": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "add": { "type": "integer", "minimum": 0 },
              "update": { "type": "integer", "minimum": 0 }
            }
          },
          "events_touched": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
