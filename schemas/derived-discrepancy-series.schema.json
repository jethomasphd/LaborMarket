{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labormarket.ai/schemas/derived-discrepancy-series.schema.json",
  "title": "Derived — Discrepancy Series",
  "description": "Auto-generated. The strategic-layer measurement: Challenger AI-CITED total vs. LaborMarket.ai B1 firm-stated, A1/A2-verified total. The gap is the metric, NOT an error to reconcile.",
  "type": "object",
  "required": ["meta", "months"],
  "additionalProperties": false,
  "properties": {
    "meta": { "type": "object", "additionalProperties": true },
    "months": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["month", "challenger_ai_cited", "lm_b1_verified", "gap"],
        "additionalProperties": false,
        "properties": {
          "month": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "challenger_ai_cited": { "type": ["integer", "null"], "minimum": 0 },
          "lm_b1_verified": { "type": "integer", "minimum": 0 },
          "lm_b1_event_count": { "type": "integer", "minimum": 0 },
          "gap": { "type": ["integer", "null"] }
        }
      }
    }
  }
}
