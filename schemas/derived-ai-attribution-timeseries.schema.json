{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labormarket.ai/schemas/derived-ai-attribution-timeseries.schema.json",
  "title": "Derived — AI Attribution Time Series",
  "description": "Auto-generated by build_rollups.py. NEVER hand-edited. Per-month event counts and headcount sums by B-tier. B-tiers are reported separately and never collapsed.",
  "type": "object",
  "required": ["meta", "months"],
  "additionalProperties": false,
  "properties": {
    "meta": { "type": "object", "additionalProperties": true },
    "months": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["month", "counts", "headcount"],
        "additionalProperties": false,
        "properties": {
          "month": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "counts": { "$ref": "#/$defs/tierbucket" },
          "headcount": { "$ref": "#/$defs/tierbucket" }
        }
      }
    }
  },
  "$defs": {
    "tierbucket": {
      "type": "object",
      "required": ["B1", "B2", "B3", "B0"],
      "additionalProperties": false,
      "properties": {
        "B1": { "type": "integer", "minimum": 0 },
        "B2": { "type": "integer", "minimum": 0 },
        "B3": { "type": "integer", "minimum": 0 },
        "B0": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
