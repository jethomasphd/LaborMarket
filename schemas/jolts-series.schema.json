{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://labormarket.ai/schemas/jolts-series.schema.json",
  "title": "JOLTS Measured Baseline",
  "description": "BLS JOLTS, SA, total nonfarm, level (thousands). The honest denominator the narrative layer lacks. Series IDs verified against a live BLS call before shipping.",
  "type": "object",
  "required": ["meta", "series"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["source", "last_pull", "api"],
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string" },
        "last_pull": { "type": "string", "format": "date" },
        "api": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "series": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/series" }
    }
  },
  "$defs": {
    "series": {
      "type": "object",
      "required": ["series_id", "unit", "observations"],
      "additionalProperties": false,
      "properties": {
        "series_id": { "type": "string", "minLength": 1 },
        "fred": { "type": ["string", "null"] },
        "label": { "type": "string" },
        "unit": { "type": "string", "enum": ["thousands", "rate_percent", "level", "percent"] },
        "seasonally_adjusted": { "type": "boolean" },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["period", "value"],
            "additionalProperties": false,
            "properties": {
              "period": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
              "value": { "type": ["number", "null"] }
            }
          }
        }
      }
    }
  }
}
